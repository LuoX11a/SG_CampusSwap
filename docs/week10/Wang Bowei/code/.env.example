# ============================================================
# SG CampusSwap — Environment Variables
# Render: Set in Dashboard → Environment
# Local: Copy to backend/.env
# ============================================================

# ─── Neon PostgreSQL ─────────────────────────────
# Get connection string from: https://console.neon.tech
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_SYNC=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ─── JWT ────────────────────────────────────────
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS (comma-separated, no spaces) ───────────
# Update with your actual Vercel domain after deploy
CORS_ORIGINS=http://localhost:3000,https://sg-campusswap.vercel.app

# ─── Environment ──────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ─── SendGrid (email verification) ────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=noreply@sgcampusswap.com

# ─── University Email Whitelist ───────────────────
ALLOWED_EMAIL_DOMAINS=u.nus.edu,nus.edu.sg,e.ntu.edu.sg,ntu.edu.sg,smu.edu.sg,sutd.edu.sg,suss.edu.sg,sit.edu.sg,connect.np.edu.sg,np.edu.sg,ichat.sp.edu.sg,sp.edu.sg,tp.edu.sg,nyp.edu.sg,rp.edu.sg,lasalle.edu.sg,nafa.edu.sg,mymail.sim.edu.sg,sim.edu.sg,jcu.edu.sg,my.jcu.edu.au

# ─── Cloudinary (image upload) ────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase (chat) ──────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=
